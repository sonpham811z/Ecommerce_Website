# ── Supabase ──────────────────────────────────────────────────────────────────
# Used by the React frontend (Vite bakes these in at build time)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Note: the PHP backend (supabase_config.php) reuses the same values above.
# docker-compose.yml maps VITE_SUPABASE_URL  → SUPABASE_URL
#                     and VITE_SUPABASE_ANON_KEY → SUPABASE_KEY at runtime.
